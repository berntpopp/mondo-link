# mondo-link local server settings (all values optional).
# MONDO_LINK_HOST=127.0.0.1
# MONDO_LINK_PORT=8000
# MONDO_LINK_TRANSPORT=unified          # unified | http | stdio
# JSON lists. Add the exact public reverse-proxy hostname in production.
# MONDO_LINK_ALLOWED_HOSTS=["localhost","127.0.0.1","::1"]
# MONDO_LINK_ALLOWED_ORIGINS=[]
# MONDO_LINK_LOG_LEVEL=INFO
# MONDO_LINK_LOG_FORMAT=console         # console | json

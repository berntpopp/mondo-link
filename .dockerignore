# Keep the build context small and the image free of secrets or data artifacts.

# VCS / CI
.git/
.gitignore
.gitattributes
.github/

# Secrets and local env files
.env
.env.*
**/.env
**/.env.*
!.env.example
!.env.docker.example
docker/.env

# Virtual environments
.venv/
venv/
env/

# Python caches and build output
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/

# Tests, docs, planning, and authoritative/runtime data
tests/
docs/
.planning/
data/
datasets/
corpus/
output/
outputs/
*.sqlite
*.sqlite-*
*.db
*.duckdb
*.parquet
*.vcf
*.bcf
*.obo
*.owl
*.tsv
*.csv
*.zst
*.gz
*.log

# Editor / OS metadata
.vscode/
.idea/
.DS_Store
